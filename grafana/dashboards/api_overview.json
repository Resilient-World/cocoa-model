{
  "uid": "cocoa-api-overview",
  "title": "Cocoa API Overview",
  "tags": ["cocoa", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Inference p95 latency by endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(cocoa_inference_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Simulation errors",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(cocoa_simulation_errors_total[5m])) by (error_class)",
          "legendFormat": "{{error_class}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Conformal coverage (rolling avg)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "cocoa_conformal_coverage_running_avg",
          "legendFormat": "{{scenario}}/{{region}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "WCTM drift score by region",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "cocoa_drift_score",
          "legendFormat": "{{region}}"
        }
      ]
    }
  ]
}

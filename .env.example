# Copy to .env and fill in locally (never commit .env)

# Google Earth Engine
# EARTHENGINE_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# EARTHENGINE_SERVICE_ACCOUNT=your-sa@project.iam.gserviceaccount.com

# MLflow
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# MLFLOW_EXPERIMENT_NAME=resilient-cocoa-model

# FastAPI
# API_HOST=0.0.0.0
# API_PORT=8000
# MODEL_CHECKPOINT_PATH=models/yield_surrogate.pt
# MC_NUM_SAMPLES=50
# YIELD_BLEND_WEIGHT=0.3

# DVC remote (example)
# DVC_REMOTE_URL=s3://your-bucket/dvc-store

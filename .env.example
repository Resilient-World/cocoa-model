# Copy to .env and fill in locally (never commit .env)

# Google Earth Engine
# EARTHENGINE_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# EARTHENGINE_SERVICE_ACCOUNT=your-sa@project.iam.gserviceaccount.com

# MLflow
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# MLFLOW_EXPERIMENT_NAME=resilient-cocoa-model

# FastAPI
# API_HOST=0.0.0.0
# API_PORT=8000
# MODEL_CHECKPOINT_PATH=models/yield_surrogate_v1.pt
# YIELD_BLEND_WEIGHT=0.0
# MC_NUM_SAMPLES=50
# YIELD_BLEND_WEIGHT=0.3
# ERA5_ZARR_PATH=data/processed/era5_2020_2024.zarr
# CMIP6_ZARR_PATH=data/processed/cmip6_ensemble.zarr
# STATIC_ZARR_PATH=data/processed/site_static.zarr
# FEATURE_CACHE_DIR=data/cache/api_features
# CLIMATE_REFERENCE_YEAR=2023
# COCOA_EXPOSURE_YEAR=2023
# FDP 2025a F1-optimal threshold (model card); see forest-data-partnership/models/cocoa
COCOA_EXPOSURE_THRESHOLD=0.96
# Exposure backend: fdp | galileo | aef | agrifm | ensemble | ensemble_v2
COCOA_EXPOSURE_BACKEND=ensemble_v2
# When using ensemble / ensemble_v2: v1 (fixed 0.5/0.3/0.2) or v2 (per-region YAML weights)
ENSEMBLE_BACKEND=v2
# ENSEMBLE_WEIGHTS_PATH=config/ensemble_weights.yaml
# AGRIFM_CHECKPOINT_PATH=models/agrifm_cocoa_seg.pt
# USE_GALILEO_EMBEDDING=false
# CONFORMAL_JSON_PATH=models/conformal.json
# UQ_METHOD=cqr
# CQR_CHECKPOINT_PATH=models/cqr_yield.pt
# CQR_CALIBRATOR_PATH=models/cqr_calibrator.joblib
# GALILEO_EMBEDDING_DIM=128

# /simulate-scenario online conformal (default: eci_integral)
# CONFORMAL_METHOD=eci_integral
# CONFORMAL_METHOD=split_cqr
# ONLINE_CONFORMAL_STATE_PATH=data/processed/online_conformal_state.json
# CONFORMAL_INITIAL_STATE_PATH=data/processed/conformal_initial_state.json
# REDIS_URL=redis://localhost:6379/0
# CONFORMAL_ALPHA=0.1
# ECI_ETA=2.5
# ECI_DECAY=0.95
# ECI_WINDOW=100

# DVC remote (example)
# DVC_REMOTE_URL=s3://your-bucket/dvc-store
